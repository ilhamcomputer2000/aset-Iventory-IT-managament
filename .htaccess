# ============================================================
# .htaccess - HOSTING VERSION (app at root /)
# For localhost XAMPP: use .htaccess.local-dev instead
# ============================================================
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    Options +FollowSymLinks
    RewriteBase /

    # 1) Pass-through existing files and directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2) Dashboard short-URL aliases
    RewriteRule ^dashboard_admin/?$ admin/dashboard_admin.php [L]
    RewriteRule ^dashboard_user/?$ user/dashboard_user.php [L]

    # 3) Extensionless URL -> .php (only paths without dots, prevents loops)
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^.]+)/?$ $1.php [L]
</IfModule>
