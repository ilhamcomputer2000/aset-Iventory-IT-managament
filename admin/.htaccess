# SSE (Server-Sent Events) must not be buffered/compressed, otherwise realtime updates will be delayed.

<Files "ticket_stream.php">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set X-Accel-Buffering "no"
    </IfModule>

    <IfModule mod_deflate.c>
        SetEnv no-gzip 1
        SetEnvIfNoCase Request_URI "ticket_stream\.php$" no-gzip dont-vary
    </IfModule>
</Files>
